# Copy to .env at repo root (never commit .env)
#   npm run setup
#
# Mặc định trỏ backend demo đã deploy — chỉ cần điền TMDB key là chạy.

# --- Frontend (Vite — cần prefix VITE_) ---
VITE_API_URL=https://x2nxz9vcxa.execute-api.ap-southeast-1.amazonaws.com
VITE_TMDB_API_KEY=your_tmdb_key

# --- Dev server + Amplify sandbox / Lambda ---
TMDB_API_KEY=your_tmdb_key

# VNPay (sandbox) — chỉ cần khi tự deploy sandbox / test thanh toán
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
FRONTEND_URL=http://localhost:5173
VNPAY_RETURN_URL=http://localhost:5173/payment/result
